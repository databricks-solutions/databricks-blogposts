# Databricks workspace URL (required)
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com

# Volume name in catalog.schema.volume format (required for DuckDB/Ray scripts)
DATABRICKS_FILE_VOLUME_NAME=volumes_cv_demo.gold.images

# AWS region for S3 access (default: us-east-1)
AWS_REGION=us-east-1
