# Databricks workspace URL (required)
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com

# Unity Catalog and schema (required)
UC_CATALOG=volumes_cv_demo
UC_SCHEMA=gold

# Volume names (just the volume name, not the full catalog.schema.volume path)
DATABRICKS_FILE_VOLUME_NAME=tabular_files
DATABRICKS_IMAGE_VOLUME_NAME=images

# Comma-separated image filenames in the volume (optional, has defaults)
IMAGE_FILENAMES=Bliss_(Windows_XP).png,flower.jpg

# AWS region for S3 access (default: us-east-1)
AWS_REGION=us-east-1
